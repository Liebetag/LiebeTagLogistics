# ═══════════════════════════════════════════════════════════════════
# LIEBE TAG LOGISTICS v4 — Environment Variables
# Copy this to .env — never commit .env to git
# ═══════════════════════════════════════════════════════════════════

# Database (Render Disk at /data)
DATABASE_URL=file:/data/liebetag.db
DB_DIR=/data

# Authentication
BOOTSTRAP_API_KEY=llt_your_api_key_here

# WhatsApp / EvolutionAPI
EVOLUTION_API_URL=https://evolution-api-production-dbc5.up.railway.app
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE=liebe-tag

# Paystack (use sk_live_ / pk_live_ for production)
PAYSTACK_SECRET_KEY=sk_test_your_key
PAYSTACK_PUBLIC_KEY=pk_test_your_key

# Cantrack GPS — token-based login
CANTRACK_SCHOOL_ID=a0882f1c-821f-4852-bccd-4ef7a3e69b08
CANTRACK_CUST_ID=a0882f1c-821f-4852-bccd-4ef7a3e69b08
CANTRACK_MDS_TOKEN=f8989b7a2dfd4c6ab524882d308dc66f
CANTRACK_SESSION=your_asp_session_cookie
CANTRACK_SECKEY=your_seckey_abvk_cookie
CANTRACK_BMAP=your_bmap_seckey_cookie

# AI
ANTHROPIC_API_KEY=sk-ant-your_key
GROQ_API_KEY=gsk_your_groq_key       # primary voice transcription, whisper-large-v3-turbo
OPENAI_API_KEY=sk-your_openai_key    # optional fallback voice transcription

# Operations (234XXXXXXXXXX format, comma-separated)
ADMIN_PHONES=2348118707226
RIDER_PHONES=2348XXXXXXXXX
RIDER_DEVICES=2348XXXXXXXXX:device_id_here

# App
APP_URL=https://liebetaglogistics-api.onrender.com
ALLOWED_ORIGINS=https://liebetag.com,https://www.liebetag.com,http://localhost:3000

PORT=8000
